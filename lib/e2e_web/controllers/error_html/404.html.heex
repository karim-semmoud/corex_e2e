<!DOCTYPE html>
<html lang="en" data-theme="neo" data-mode="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{~t"Page Not Found"}</title>
    <link phx-track-static rel="stylesheet" href="/assets/css/app.css" />
  </head>
  <body class="layout typo bg-root text-ink min-h-screen">
    <main
      id="main-content"
      class="layout__main layout__main--marketing flex min-h-screen flex-col items-center justify-center gap-space-lg p-space-lg"
    >
      <div class="layout__article flex max-w-prose flex-col items-center gap-space-lg text-center">
        <p class="m-0 font-display text-display-sm text-ink-accent">404</p>
        <h1 class="m-0">{~t"Page Not Found"}</h1>
        <p class="m-0 text-ink-muted">
          {~t"Sorry, the page you are looking for does not exist."}
        </p>
        <.navigate to={~p"/"} class="button button--accent button--lg">
          {~t"Go home"}
        </.navigate>
      </div>
    </main>
  </body>
</html>
