<Layouts.app
  flash={@flash}
  mode={@mode}
  theme={@theme}
  locale={@locale}
  current_path={@current_path}
>
  <.layout_heading>
    <:title>Switch</:title>
    <:subtitle>Controller View</:subtitle>
  </.layout_heading>
  <.switch class="switch">
    <:label>Enable notifications</:label>
  </.switch>
</Layouts.app>
