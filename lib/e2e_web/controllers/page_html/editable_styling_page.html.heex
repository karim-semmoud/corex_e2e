<Layouts.app
  flash={@flash}
  mode={@mode}
  theme={@theme}
  path={@path}
>
  <.demo_page
    id="editable-styling-page"
    title="Editable · Style"
    subtitle="Density via modifier classes on the editable root."
  >
    <.demo_section
      id="editable-styling-size"
      title="Size"
      code={E2eWeb.Demos.EditableDemo.styling_size_code()}
    >
      <:preview>
        <E2eWeb.Demos.EditableDemo.styling_size_example />
      </:preview>
    </.demo_section>
  </.demo_page>
</Layouts.app>
