<Layouts.app
  flash={@flash}
  mode={@mode}
  theme={@theme}
  path={@path}
>
  <.demo_page
    path={@path}
    id="navigate-style-page"
    title={~t"Navigate · Style"}
    subtitle={~t"Color and size modifiers on class=\"link\"."}
  >
    <.demo_section
      id="navigate-style-color"
      title={~t"Color"}
      code={E2eWeb.Demos.NavigateDemo.styling_color_code()}
    >
      <:preview><E2eWeb.Demos.NavigateDemo.styling_color_example /></:preview>
    </.demo_section>

    <.demo_section
      id="navigate-style-size"
      title={~t"Size"}
      code={E2eWeb.Demos.NavigateDemo.styling_size_code()}
    >
      <:preview><E2eWeb.Demos.NavigateDemo.styling_size_example /></:preview>
    </.demo_section>
  </.demo_page>
</Layouts.app>
