<Layouts.app
  flash={@flash}
  mode={@mode}
  theme={@theme}
  locale={@locale}
  current_path={@current_path}
>
  <.layout_heading>
    <:title>Pin Input</:title>
    <:subtitle>Controller View</:subtitle>
  </.layout_heading>
  <.pin_input id="my-pin-input" count={4} class="pin-input">
    <:label>Code</:label>
  </.pin_input>
</Layouts.app>
